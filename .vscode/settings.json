{
    "editor.formatOnType": true,
    "editor.formatOnSave": true,
    "[vue]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "editor.tabSize": 2,
    "editor.formatOnPaste": true,
    "editor.guides.bracketPairs": "active",
    "files.autoSave": "afterDelay",
    "git.confirmSync": false,
    "workbench.startupEditor": "newUntitledFile",
    "editor.suggestSelection": "first",
    "editor.acceptSuggestionOnCommitCharacter": false,
    "css.lint.propertyIgnoredDueToDisplay": "ignore",
    "editor.quickSuggestions": {
      "other": true,
      "comments": true,
      "strings": true
    },
    "files.associations": {
      "editor.snippetSuggestions": "top"
    },
    "[css]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    },
    "i18n-ally.localesPaths": "locales",
    "i18n-ally.keystyle": "nested",
    "i18n-ally.sortKeys": true,
    "i18n-ally.namespace": true,
    "i18n-ally.enabledParsers": [
      "yaml",
      "js"
    ],
    "i18n-ally.sourceLanguage": "en",
    "i18n-ally.displayLanguage": "zh-CN",
    "i18n-ally.enabledFrameworks": [
      "vue"
    ],
    "iconify.excludes": [
      "el"
    ],
    "vsmqtt.brokerProfiles": [
      {
        "name": "broker.emqx.io",
        "host": "broker.emqx.io/mqtt",
        "port": 1883,
        "clientId": "vsmqtt_client_db34"
      }
    ],
    "vscodeCustomCodeColor.highlightValue": [
      "v-loading",
      "v-auth",
      "v-copy",
      "v-longpress",
      "v-optimize",
      "v-perms",
      "v-ripple"
    ],
    "vscodeCustomCodeColor.highlightValueColor": "#b392f0",
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.profiles.linux": {
        "nvitop":{
            "path": "/bin/zsh",
            "args": [
                "-c",
                "nvitop"
                ],
                "name": "Start nvitop",
                "description": "Terminal profile that runs a command on startup"
        },
        "nload":{
            "path": "/bin/zsh",
            "args": [
                "-c",
                "nload -u M eth0"
                ],
                "name": "Start nvitop",
                "description": "Terminal profile that runs a command on startup"
        },
        "btop":{
            "path": "/bin/zsh",
            "args": [
                "-c",
                "btop -u 1000"
                ],
                "name": "Start btop",
                "description": "Terminal profile that runs a command on startup"
        },
        "构建开发环境":{
            "path": "/bin/zsh",
            "args": [
                "-c",
                "zsh /workspace/build-env.sh"
                ],
                "name": "Start build env image",
                "description": "Terminal profile that runs a command on startup"
        },
        "构建项目镜像":{
            "path": "/bin/zsh",
            "args": [
                "-c",
                "zsh /workspace/build.sh"
                ],
                "name": "Start build image",
                "description": "Terminal profile that runs a command on startup"
        },
        "晚安！":{
            "path": "/bin/zsh",
            "args": [
                "-c",
                "kill 1"
                ],
                "name": "Go to sleep",
                "description": "Terminal profile that runs a command on startup"
        },
        "zsh": {
            "path": "/bin/zsh"
        },
        "代码风格检查": {
            "path": "/bin/zsh",
            "args": [
                "-c",
                "zsh /workspace/lint.sh && zsh"
                ],
        },
        "前端启动":{
          "path": "/bin/zsh",
          "args": [
            "-c",
            "cd /workspace/frontend && bun i && bun dev"
          ]
        },
        "后端启动": {
          "path": "/bin/zsh",
          "args": [
            "-c",
            "cd /workspace/backend && uv run main.py"
          ]
        },
        "更新版本-补丁": {
          "path": "/bin/zsh",
          "args": [
            "-c",
            "cd /workspace && python scripts/update-version.py --patch"
          ],
          "name": "Update Patch Version",
          "description": "更新补丁版本号 (x.y.z+1)"
        },
        "更新版本-次版本": {
          "path": "/bin/zsh",
          "args": [
            "-c",
            "cd /workspace && python scripts/update-version.py --minor"
          ],
          "name": "Update Minor Version",
          "description": "更新次版本号 (x.y+1.0)"
        },
        "更新版本-主版本": {
          "path": "/bin/zsh",
          "args": [
            "-c",
            "cd /workspace && python scripts/update-version.py --major"
          ],
          "name": "Update Major Version",
          "description": "更新主版本号 (x+1.0.0)"
        },
        "更新版本-自定义": {
          "path": "/bin/zsh",
          "args": [
            "-c",
            "read -p '请输入新版本号: ' version && cd /workspace && python scripts/update-version.py $version"
          ],
          "name": "Update Custom Version",
          "description": "输入自定义版本号进行更新"
        },
        "同步版本信息": {
          "path": "/bin/zsh",
          "args": [
            "-c",
            "cd /workspace && python scripts/update-version.py"
          ],
          "name": "Sync Version Info",
          "description": "同步所有文件的版本信息"
        },
        "查看当前版本": {
          "path": "/bin/zsh",
          "args": [
            "-c",
            "cd /workspace && python scripts/update-version.py --show && zsh"
          ],
          "name": "Show Current Version",
          "description": "查看当前项目的版本信息"
        }
    },
    "gitblame.inlineMessageEnabled": true,
    "gitblame.inlineMessageFormat": "${author.name}, (${time.ago}) · ${commit.summary}",
    "python.analysis.autoImportCompletions": true,
    "python.linting.enabled": true,
    "python.linting.lintOnSave": true,
    "python.languageServer": "Pylance",
    "python.defaultInterpreterPath": "/workspace/backend/.venv/bin/python",
    "workbench.iconTheme": "vscode-icons",
    "codingcopilot.welcomeMessage": "never",
    "gitlens.showWelcomeOnInstall": false,
    "vue.showWelcomePage": false,
    "editor.fontFamily": "'JetBrains Mono', Consolas, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 15,
    "editor.fontWeight": "normal",
    "vsicons.dontShowNewVersionMessage": true,
    "yaml.schemaStore.enable": false,
    "yaml.trace.server": "off",
    "redhat.telemetry.enabled": false,
    "github.copilot.enable": false,
    "sqltools.connections": [
      {
        "previewLimit": 50,
        "driver": "SQLite",
        "name": "test",
        "group": "test",
        "database": "${workspaceFolder:workspace}/backend/static/pytool.sqlite"
      }
    ],
    "sqltools.useNodeRuntime": true,
    "gitblame.inlineMessageEnabled": true,
    "gitblame.inlineMessageFormat": "${author.name}, (${time.ago}) · ${commit.summary}",
    "terminal.integrated.suggest.enabled": true,
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "terminal.integrated.shellIntegration.environmentReporting": true,
    "codingcopilot.autoRun": true
}