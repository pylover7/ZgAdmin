# ╔══════════════════════════════════════════════════════════════════╗
# ║  ZgAdmin 配置文件                                                 ║
# ║  首次运行: ./scripts/start.sh 会自动从此文件创建 .env          ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── 运行模式 ──────────────────────────────────────────────────────
ENVIRONMENT=local              # local | staging | production
HOST=0.0.0.0
PORT=7001
DEBUG=True
RELOAD=True

# ─── 安全（生产环境务必修改） ──────────────────────────────────────
SECRET_KEY=changethis          # 生成: openssl rand -hex 32
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_PASSWORD=admin123456   # 生产环境务必修改

# ─── 前端地址 & 跨域 ───────────────────────────────────────────────
FRONTEND_HOST=http://localhost:7000
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:7000"

# ─── 数据库（默认 SQLite，零配置即用） ─────────────────────────────
#     切换到 PostgreSQL: 改 DB_SCHEME=postgresql 并填写下方配置
DB_SCHEME=sqlite               # sqlite | postgresql | mysql
DB_SERVER=localhost
DB_PORT=5432
DB_PATH=zgadmin.sqlite
DB_USER=changethis
DB_PASSWORD=changethis

# ─── 邮件（可选，不填则不启用） ────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com

# ─── QQ 登录（可选，留空则前端自动隐藏入口） ───────────────────────
QQ_APP_ID=
QQ_APP_KEY=
QQ_REDIRECT_URI=http://localhost:7000/login/qq/callback

# ─── 监控（可选） ──────────────────────────────────────────────────
SENTRY_DSN=

# ─── 功能开关 ──────────────────────────────────────────────────────
FEATURE_QQ_LOGIN=False          # QQ 登录（需同时配置上方 QQ_APP_ID）
FEATURE_WECHAT_LOGIN=False      # 微信登录
FEATURE_EMAIL=False             # 邮件发送（需同时配置上方 SMTP）
FEATURE_MONITOR_LOG=True        # 操作日志记录

# ———— 前端环境变量 ————————————————————
# 平台本地运行端口号
VITE_PORT = 7000

# 是否隐藏首页 隐藏 true 不隐藏 false （勿删除，VITE_HIDE_HOME只需在.env文件配置）
VITE_HIDE_HOME = false
