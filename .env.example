# ─── 运行模式 ──────────────────────────────────────────────────────
ENVIRONMENT=local
HOST=0.0.0.0
PORT=7001
WORKERS=1
DEBUG=True
RELOAD=True

# ─── 安全（生产环境务必修改） ──────────────────────────────────────
SECRET_KEY=changethis
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_PASSWORD=admin123456

# ─── 前端地址 & 跨域 ───────────────────────────────────────────────
FRONTEND_HOST=http://localhost:7000
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:7000"

# ─── 数据库（默认 SQLite，零配置即用） ─────────────────────────────
DB_SCHEME=sqlite
DB_SERVER=localhost
DB_PORT=5432
DB_PATH=zgadmin.sqlite
DB_USER=changethis
DB_PASSWORD=changethis

# ─── Redis（开发环境留空使用内存模拟，生产环境需配置） ─────────────
REDIS_URL=

# ─── 邮件（可选，不填则不启用） ────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com

# ─── QQ 登录（可选，留空则前端自动隐藏入口） ───────────────────────
QQ_APP_ID=
QQ_APP_KEY=
QQ_REDIRECT_URI=http://localhost:7000/login/qq/callback

# ─── 监控（可选） ──────────────────────────────────────────────────
SENTRY_DSN=

# ─── 功能开关 ──────────────────────────────────────────────────────
FEATURE_QQ_LOGIN=False
FEATURE_WECHAT_LOGIN=False
FEATURE_EMAIL=False
FEATURE_MONITOR_LOG=True
